<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'pt' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <title>Error - <%= typeof t !== 'undefined' ? t('title') : 'Bolão Copa 2026' %></title>
    <link rel="stylesheet" href="/css/style.css">
    <meta name="theme-color" content="#1e3c72">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
</head>
<body>
    <div class="container">
        <div class="error-container">
            <h1>⚠️ Oops!</h1>
            <p class="error-message"><%= mensagem %></p>
            <a href="/?lang=<%= typeof lang !== 'undefined' ? lang : 'pt' %>" class="btn-voltar"><%= typeof t !== 'undefined' ? t('backToHome') : 'Voltar' %></a>
        </div>
    </div>
</body>
</html>
