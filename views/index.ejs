<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>⚽ <%= titulo %></h1>
            <p>Faça seus palpites nos jogos abaixo!</p>
        </header>

        <% if (error) { %>
            <div class="alert alert-error">
                <%= error %>
            </div>
        <% } %>

        <% if (success) { %>
            <div class="alert alert-success">
                <%= success %>
            </div>
        <% } %>

        <main>
            <% jogos.forEach(jogo => { %>
                <div class="jogo-card">
                    <div class="jogo-header">
                        <span class="jogo-data">📅 <%= jogo.dataHoraFormatada %></span>
                        <% if (!jogo.permiteApostas) { %>
                            <span class="badge encerrado">Apostas Encerradas</span>
                        <% } else { %>
                            <span class="badge aberto">Apostas Abertas</span>
                        <% } %>
                    </div>
                    
                    <div class="jogo-times">
                        <div class="time">
                            <span class="bandeira">🏳️</span>
                            <span class="nome"><%= jogo.time1 %></span>
                        </div>
                        <span class="vs">VS</span>
                        <div class="time">
                            <span class="bandeira">🏳️</span>
                            <span class="nome"><%= jogo.time2 %></span>
                        </div>
                    </div>

                    <% if (jogo.permiteApostas) { %>
                        <form action="/apostar" method="POST" class="aposta-form">
                            <input type="hidden" name="jogo_id" value="<%= jogo.id %>">
                            
                            <div class="form-group">
                                <label for="nome-<%= jogo.id %>">Seu Nome:</label>
                                <input type="text" 
                                       id="nome-<%= jogo.id %>" 
                                       name="nome" 
                                       required 
                                       placeholder="Digite seu nome">
                            </div>
                            
                            <div class="placar-inputs">
                                <div class="placar-time">
                                    <label><%= jogo.time1 %></label>
                                    <input type="number" 
                                           name="palpite_time1" 
                                           min="0" 
                                           required 
                                           placeholder="0">
                                </div>
                                <span class="vs-small">X</span>
                                <div class="placar-time">
                                    <label><%= jogo.time2 %></label>
                                    <input type="number" 
                                           name="palpite_time2" 
                                           min="0" 
                                           required 
                                           placeholder="0">
                                </div>
                            </div>
                            
                            <button type="submit" class="btn-apostar">Fazer Aposta</button>
                        </form>
                    <% } %>

                    <div class="apostas-section">
                        <h4>📊 Apostas Registradas</h4>
                        <% if (jogo.apostas.length === 0) { %>
                            <p class="sem-apostas">Nenhuma aposta registrada ainda.</p>
                        <% } else { %>
                            <ul class="lista-apostas">
                                <% jogo.apostas.forEach(aposta => { %>
                                    <li>
                                        <span class="apostador"><%= aposta.nome %></span>
                                        <span class="palpite">
                                            <%= aposta.palpite_time1 %> x <%= aposta.palpite_time2 %>
                                        </span>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </main>

        <footer>
            <p>Bolão Copa 2026 - Desenvolvido com Node.js e Express</p>
        </footer>
    </div>
</body>
</html>
