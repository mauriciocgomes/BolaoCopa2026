<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <title><%= titulo %></title>
    <link rel="stylesheet" href="/css/style.css">
    <meta name="theme-color" content="#1e3c72">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
</head>
<body>
    <div class="container">
        <header>
            <div class="lang-selector">
                <a href="?lang=pt<%= error ? '&error=' + encodeURIComponent(error) : '' %><%= success ? '&success=' + encodeURIComponent(success) : '' %>" class="lang-btn <%= lang === 'pt' ? 'active' : '' %>">🇧🇷 <%= t('langPortuguese') %></a>
                <a href="?lang=en<%= error ? '&error=' + encodeURIComponent(error) : '' %><%= success ? '&success=' + encodeURIComponent(success) : '' %>" class="lang-btn <%= lang === 'en' ? 'active' : '' %>">🇺🇸 <%= t('langEnglish') %></a>
                <a href="/admin/resultados?lang=<%= lang %>" class="lang-btn" style="background: #dc3545; margin-left: 10px;">⚙️ Admin</a>
            </div>
            <h1>⚽ <%= titulo %></h1>
            <p><%= t('subtitle') %></p>
        </header>

        <% if (error) { %>
            <div class="alert alert-error">
                <%= error %>
            </div>
        <% } %>

        <% if (success) { %>
            <div class="alert alert-success">
                <%= success %>
            </div>
        <% } %>

        <% if (ranking && ranking.length > 0) { %>
            <div class="ranking-section">
                <h3>🏆 Ranking de Pontos</h3>
                <div class="ranking-list">
                    <% ranking.forEach((participante, index) => { %>
                        <div class="ranking-item <%= index === 0 ? 'primeiro' : index === 1 ? 'segundo' : index === 2 ? 'terceiro' : '' %>" onclick="window.location.href='/participante/<%= encodeURIComponent(participante.nome) %>?lang=<%= lang %>'" style="cursor: pointer;">
                            <span class="ranking-posicao"><%= index + 1 %>º</span>
                            <span class="ranking-nome"><%= participante.nome %></span>
                            <span class="ranking-pontos"><%= participante.totalPontos %> pts</span>
                            <% if (participante.placaresExatos > 0 || participante.resultadosCorretos > 0) { %>
                                <span class="ranking-detalhes">
                                    <%= participante.placaresExatos %>🥇 <%= participante.resultadosCorretos %>✅
                                </span>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>

        <main>
            <%# JOGOS DE HOJE %>
            <% if (jogosDeHoje && jogosDeHoje.length > 0) { %>
                <div class="secao-jogos-hoje">
                    <h2 class="titulo-secao">⚽ <%= t('todayGames') %></h2>
                    <% jogosDeHoje.forEach(jogo => { %>
                        <div class="jogo-card jogo-hoje">
                            <div class="jogo-header">
                                <span class="jogo-data">📅 <%= jogo.dataHoraFormatada %></span>
                                <span class="badge aberto"><%= t('betsOpen') %></span>
                            </div>
                            
                            <div class="jogo-times">
                                <div class="time">
                                    <span class="bandeira"><%= jogo.bandeira1 %></span>
                                    <span class="nome"><%= jogo.time1 %></span>
                                </div>
                                <span class="vs">VS</span>
                                <div class="time">
                                    <span class="bandeira"><%= jogo.bandeira2 %></span>
                                    <span class="nome"><%= jogo.time2 %></span>
                                </div>
                            </div>

                            <% if (jogo.resultado) { %>
                                <div class="resultado-oficial">
                                    <span class="resultado-label">🏆 <%= t('officialResult') %>:</span>
                                    <span class="resultado-placar"><%= jogo.resultado.placar_time1 %> x <%= jogo.resultado.placar_time2 %></span>
                                </div>
                            <% } %>

                            <form action="/apostar" method="POST" class="aposta-form">
                                <input type="hidden" name="jogo_id" value="<%= jogo.id %>">
                                
                                <div class="form-group">
                                    <label for="nome-<%= jogo.id %>"><%= t('yourName') %></label>
                                    <select id="nome-<%= jogo.id %>" name="nome" required class="select-participante">
                                        <option value="">Selecione...</option>
                                        <% participantes.forEach(participante => { %>
                                            <option value="<%= participante %>"><%= participante %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                
                                <div class="placar-inputs">
                                    <div class="placar-time">
                                        <label><%= jogo.time1 %></label>
                                        <input type="number" name="palpite_time1" min="0" required placeholder="0">
                                    </div>
                                    <span class="vs-small">X</span>
                                    <div class="placar-time">
                                        <label><%= jogo.time2 %></label>
                                        <input type="number" name="palpite_time2" min="0" required placeholder="0">
                                    </div>
                                </div>
                                
                                <input type="hidden" name="lang" value="<%= lang %>">
                                <button type="submit" class="btn-apostar"><%= t('placeBet') %></button>
                            </form>

                            <div class="apostas-section">
                                <h4>📊 <%= t('betsRegistered') %></h4>
                                <% if (jogo.resultado) { %>
                                    <div class="pontos-legenda">
                                        <span class="legenda-item legenda-exato">🥇 <%= t('pointsExact') %></span>
                                        <span class="legenda-item legenda-resultado">✅ <%= t('pointsResult') %></span>
                                    </div>
                                <% } %>
                                <% if (jogo.apostas.length === 0) { %>
                                    <p class="sem-apostas"><%= t('noBets') %></p>
                                <% } else { %>
                                    <ul class="lista-apostas">
                                        <% jogo.apostas.forEach(aposta => { %>
                                            <li>
                                                <span class="apostador"><%= aposta.nome %></span>
                                                <span class="palpite">
                                                    <%= aposta.palpite_time1 %> x <%= aposta.palpite_time2 %>
                                                </span>
                                                <% if (aposta.pontos > 0) { %>
                                                    <span class="pontos-badge <%= aposta.pontos === 3 ? 'pontos-exato' : 'pontos-resultado' %>">
                                                        +<%= aposta.pontos %> <%= t('points') %>
                                                    </span>
                                                <% } %>
                                            </li>
                                        <% }) %>
                                    </ul>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
            
            <%# OUTROS JOGOS %>
            <% if (outrosJogos && outrosJogos.length > 0) { %>
                <div class="secao-outros-jogos">
                    <h2 class="titulo-secao">📅 <%= t('upcomingGames') %></h2>
                    <% outrosJogos.forEach(jogo => { %>
                        <div class="jogo-card">
                            <div class="jogo-header">
                                <span class="jogo-data">📅 <%= jogo.dataHoraFormatada %></span>
                                <span class="badge aberto"><%= t('betsOpen') %></span>
                            </div>
                            
                            <div class="jogo-times">
                                <div class="time">
                                    <span class="bandeira"><%= jogo.bandeira1 %></span>
                                    <span class="nome"><%= jogo.time1 %></span>
                                </div>
                                <span class="vs">VS</span>
                                <div class="time">
                                    <span class="bandeira"><%= jogo.bandeira2 %></span>
                                    <span class="nome"><%= jogo.time2 %></span>
                                </div>
                            </div>

                            <% if (jogo.resultado) { %>
                                <div class="resultado-oficial">
                                    <span class="resultado-label">🏆 <%= t('officialResult') %>:</span>
                                    <span class="resultado-placar"><%= jogo.resultado.placar_time1 %> x <%= jogo.resultado.placar_time2 %></span>
                                </div>
                            <% } %>

                            <form action="/apostar" method="POST" class="aposta-form">
                                <input type="hidden" name="jogo_id" value="<%= jogo.id %>">
                                
                                <div class="form-group">
                                    <label for="nome-<%= jogo.id %>"><%= t('yourName') %></label>
                                    <select id="nome-<%= jogo.id %>" name="nome" required class="select-participante">
                                        <option value="">Selecione...</option>
                                        <% participantes.forEach(participante => { %>
                                            <option value="<%= participante %>"><%= participante %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                
                                <div class="placar-inputs">
                                    <div class="placar-time">
                                        <label><%= jogo.time1 %></label>
                                        <input type="number" name="palpite_time1" min="0" required placeholder="0">
                                    </div>
                                    <span class="vs-small">X</span>
                                    <div class="placar-time">
                                        <label><%= jogo.time2 %></label>
                                        <input type="number" name="palpite_time2" min="0" required placeholder="0">
                                    </div>
                                </div>
                                
                                <input type="hidden" name="lang" value="<%= lang %>">
                                <button type="submit" class="btn-apostar"><%= t('placeBet') %></button>
                            </form>

                            <div class="apostas-section">
                                <h4>📊 <%= t('betsRegistered') %></h4>
                                <% if (jogo.resultado) { %>
                                    <div class="pontos-legenda">
                                        <span class="legenda-item legenda-exato">🥇 <%= t('pointsExact') %></span>
                                        <span class="legenda-item legenda-resultado">✅ <%= t('pointsResult') %></span>
                                    </div>
                                <% } %>
                                <% if (jogo.apostas.length === 0) { %>
                                    <p class="sem-apostas"><%= t('noBets') %></p>
                                <% } else { %>
                                    <ul class="lista-apostas">
                                        <% jogo.apostas.forEach(aposta => { %>
                                            <li>
                                                <span class="apostador"><%= aposta.nome %></span>
                                                <span class="palpite">
                                                    <%= aposta.palpite_time1 %> x <%= aposta.palpite_time2 %>
                                                </span>
                                                <% if (aposta.pontos > 0) { %>
                                                    <span class="pontos-badge <%= aposta.pontos === 3 ? 'pontos-exato' : 'pontos-resultado' %>">
                                                        +<%= aposta.pontos %> <%= t('points') %>
                                                    </span>
                                                <% } %>
                                            </li>
                                        <% }) %>
                                    </ul>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </main>

        <footer>
            <p><%= t('footer') %></p>
        </footer>
    </div>
</body>
</html>
