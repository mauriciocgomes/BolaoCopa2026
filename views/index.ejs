<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <title><%= titulo %></title>
    <link rel="stylesheet" href="/css/style.css">
    <meta name="theme-color" content="#1e3c72">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
</head>
<body>
    <div class="container">
        <header>
            <div class="lang-selector">
                <a href="?lang=pt<%= error ? '&error=' + encodeURIComponent(error) : '' %><%= success ? '&success=' + encodeURIComponent(success) : '' %>" class="lang-btn <%= lang === 'pt' ? 'active' : '' %>">🇧🇷 <%= t('langPortuguese') %></a>
                <a href="?lang=en<%= error ? '&error=' + encodeURIComponent(error) : '' %><%= success ? '&success=' + encodeURIComponent(success) : '' %>" class="lang-btn <%= lang === 'en' ? 'active' : '' %>">🇺🇸 <%= t('langEnglish') %></a>
                <a href="/admin/resultados?lang=<%= lang %>" class="lang-btn" style="background: #dc3545; margin-left: 10px;">⚙️ Admin</a>
            </div>
            <h1>⚽ <%= titulo %></h1>
            <p><%= t('subtitle') %></p>
        </header>

        <% if (error) { %>
            <div class="alert alert-error">
                <%= error %>
            </div>
        <% } %>

        <% if (success) { %>
            <div class="alert alert-success">
                <%= success %>
            </div>
        <% } %>

        <% if (ranking && ranking.length > 0) { %>
            <div class="ranking-section">
                <h3>🏆 Ranking de Pontos</h3>
                <div class="ranking-list">
                    <% ranking.forEach((participante, index) => { %>
                        <div class="ranking-item <%= index === 0 ? 'primeiro' : index === 1 ? 'segundo' : index === 2 ? 'terceiro' : '' %>">
                            <span class="ranking-posicao"><%= index + 1 %>º</span>
                            <span class="ranking-nome"><%= participante.nome %></span>
                            <span class="ranking-pontos"><%= participante.totalPontos %> pts</span>
                            <% if (participante.placaresExatos > 0 || participante.resultadosCorretos > 0) { %>
                                <span class="ranking-detalhes">
                                    <%= participante.placaresExatos %>🥇 <%= participante.resultadosCorretos %>✅
                                </span>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>

        <main>
            <%# JOGOS DE HOJE %>
            <% if (jogosDeHoje && jogosDeHoje.length > 0) { %>
                <div class="secao-jogos-hoje">
                    <h2 class="titulo-secao">⚽ Jogos de Hoje</h2>
                    <% jogosDeHoje.forEach(jogo => { %>
                        <%- include('partials/jogo-card', {jogo: jogo, participantes: participantes, t: t, lang: lang}) %>
                    <% }) %>
                </div>
            <% } %>
            
            <%# OUTROS JOGOS %>
            <% if (outrosJogos && outrosJogos.length > 0) { %>
                <div class="secao-outros-jogos">
                    <h2 class="titulo-secao">📅 Próximos Jogos</h2>
                    <% outrosJogos.forEach(jogo => { %>
                        <%- include('partials/jogo-card', {jogo: jogo, participantes: participantes, t: t, lang: lang}) %>
                    <% }) %>
                </div>
            <% } %>
        </main>

        <footer>
            <p><%= t('footer') %></p>
        </footer>
    </div>
</body>
</html>
